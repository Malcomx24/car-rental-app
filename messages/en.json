  "privacy": {
    "title": "Privacy Policy",
    "lastUpdated": "Last updated",
    "introTitle": "Introduction",
    "introText": "DriveRent (\"we,\" \"our,\" or \"us\") is committed to protecting your privacy. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our car rental services and website.",
    "infoTitle": "Information We Collect",
    "infoText": "We may collect information that you provide directly, including your name, email address, phone number, driver's license information, payment details, and rental preferences. We also automatically collect certain information about your device and usage of our services.",
    "usageTitle": "How We Use Your Information",
    "usageText": "We use your information to process rentals, communicate with you about your bookings, improve our services, send promotional materials (with your consent), and ensure the security of our platform.",
    "sharingTitle": "Information Sharing",
    "sharingText": "We do not sell your personal information. We may share your data with service providers who assist in our operations, insurance companies for claims processing, and law enforcement when required by law.",
    "securityTitle": "Data Security",
    "securityText": "We implement industry-standard security measures including encryption, secure servers, and regular security audits. However, no method of transmission over the Internet is 100% secure.",
    "rightsTitle": "Your Rights",
    "rightsText": "You have the right to access, correct, or delete your personal information. You can also opt out of marketing communications at any time. Contact us to exercise these rights.",
    "contactTitle": "Contact Us",
    "contactText": "If you have questions about this Privacy Policy, please contact us at privacy@driverent.com."
  },
